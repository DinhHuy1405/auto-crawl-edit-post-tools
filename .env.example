# ============================================================
# COPY FILE NÀY THÀNH .env VÀ ĐIỀN GIÁ TRỊ THẬT VÀO
# cp .env.example .env
# ============================================================

# ─── JDownloader Credentials ─────────────────────────────────
# Tài khoản my.jdownloader.org (dùng để remote control JDownloader)
JD_EMAIL=your_email@example.com
JD_PASSWORD=your_password
JD_DEVICE=JDownloader@your_device_name

# ─── YouTube Data API Key ────────────────────────────────────
# Lấy từ: https://console.cloud.google.com → APIs & Services → YouTube Data API v3
YOUTUBE_API_KEY=AIzaSy_YOUR_YOUTUBE_DATA_API_KEY
